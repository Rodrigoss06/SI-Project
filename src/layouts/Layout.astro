---
import { ViewTransitions } from 'astro:transitions';
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ViewTransitions />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --blue: #1a6fc4;
        --blue-dark: #0f4e8f;
        --blue-light: #e8f0fb;
        --teal: #0d9e7e;
        --red: #c0392b;
        --red-light: #fdecea;
        --orange: #e67e22;
        --orange-light: #fef5ec;
        --green: #27ae60;
        --green-light: #eafaf1;
        --gray: #7f8c8d;
        --gray-light: #f4f6f9;
        --white: #ffffff;
        --text: #2c3e50;
        --border: #dce1e9;
        --shadow: 0 2px 12px rgba(0,0,0,0.08);
        --radius: 12px;
      }
      body {
        font-family: 'Segoe UI', system-ui, sans-serif;
        background: var(--gray-light);
        color: var(--text);
        min-height: 100vh;
      }
      header {
        background: linear-gradient(135deg, var(--blue-dark), var(--blue));
        color: white;
        padding: 1.2rem 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
      }
      header .logo {
        font-size: 1.8rem;
      }
      header h1 {
        font-size: 1.3rem;
        font-weight: 600;
        letter-spacing: 0.3px;
      }
      header p {
        font-size: 0.85rem;
        opacity: 0.8;
      }
      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1rem;
      }
      .card {
        background: var(--white);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
      }
      .card h2 {
        font-size: 1rem;
        font-weight: 700;
        color: var(--blue-dark);
        margin-bottom: 1rem;
        padding-bottom: 0.6rem;
        border-bottom: 2px solid var(--blue-light);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.8rem;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: all 0.2s;
        text-decoration: none;
      }
      .btn-primary {
        background: var(--blue);
        color: white;
      }
      .btn-primary:hover { background: var(--blue-dark); transform: translateY(-1px); }
      .btn-secondary {
        background: var(--gray-light);
        color: var(--text);
        border: 1px solid var(--border);
      }
      .btn-secondary:hover { background: var(--border); }
      .tag {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <header>
      <span class="logo">🏥</span>
      <div>
        <h1 transition:name="site-title">Sistema Experto — Diagnóstico de Varicela</h1>
        <p>Inteligencia Artificial aplicada a la medicina</p>
      </div>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
